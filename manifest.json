{
  "manifest_version": 3,
  "name": "AI Webnovel Translator Experimental",
  "version": "3.0.1",
  "browser_specific_settings": {
    "gecko": {
      "id": "{4c5a03a4-c0a1-4978-b840-9cbd90a43e18}",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "description": "Extracts text from Syosetsu/Kakuyomu/Booktoki/generic novel sites and translates them using Gemini, Vertex AI, OpenRouter, OpenAI-compatible, GLM Coding, or ChatGPT/Gemini web automation. Bring your own key.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "scripting"
  ],
  "action": {
    "default_title": "Translate Webnovel",
    "default_icon": {
      "48": "48.png"
    }
  },
  "background": {
    "service_worker": "service_worker.js",
    "scripts": [
      "browser-polyfill.min.js",
      "service_worker.js"
    ]
  },
  "icons": {
    "48": "48.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": [
        "chunks.html",
        "chunks.js",
        "marked.min.js",
        "purify.min.js",
        "browser-polyfill.min.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "browser-polyfill.min.js",
        "chatgpt_injector.js"
      ]
    },
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": [
        "browser-polyfill.min.js",
        "gemini_injector.js"
      ]
    }
  ]
}